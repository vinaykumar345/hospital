{
  "title": "AI Hospital Assistant API Overview",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency p95",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    }
  ]
}
